# Google Gemini AI (Primary)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter AI (Backup / Fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-ultra

# AI Provider Strategy: "gemini" | "openrouter" | "auto"
# auto = Coba Gemini dulu, fallback ke OpenRouter jika gagal
AI_PROVIDER=auto

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/dprd_chatbot?sslmode=require

# Server
PORT=3000
NODE_ENV=development
